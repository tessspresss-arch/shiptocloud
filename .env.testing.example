APP_NAME="Medisys Pro (Testing)"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://cabinet-medical-laravel.test

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Recommande: base MySQL dediee aux tests pour eviter tout impact sur les donnees locales
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medisys_test
DB_USERNAME=root
DB_PASSWORD=

# Option si sqlite est active dans PHP:
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:

CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

BCRYPT_ROUNDS=4
ALLOW_NON_TEST_DB=false
