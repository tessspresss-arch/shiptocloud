@push('scripts')
<!-- FullCalendar JS -->
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/fr.min.js'></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let currentAppointmentId = null;

    // Initialiser FullCalendar
    const calendarEl = document.getElementById('calendar');
    const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'timeGridWeek',
        locale: 'fr',
        headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
        },
        events: '/api/rendezvous',
        editable: true,
        selectable: true,
        selectMirror: true,
        dayMaxEvents: true,
        weekends: true,
        businessHours: {
            daysOfWeek: [1, 2, 3, 4, 5],
            startTime: '08:00',
            endTime: '19:00'
        },
        slotDuration: '00:15:00',
        slotLabelInterval: '01:00',
        slotMinTime: '08:00',
        slotMaxTime: '20:00',
        allDaySlot: false,
        select: function(info) {
            // Quand l'utilisateur sélectionne une plage horaire
            document.getElementById('dateHeureInput').value = info.startStr.substring(0, 16);
            const modal = new bootstrap.Modal(document.getElementById('appointmentModal'));
            document.getElementById('appointmentModalTitle').textContent = 'Nouveau Rendez-vous';
            currentAppointmentId = null;
            document.getElementById('appointmentForm').reset();
            modal.show();
        },
        eventClick: function(info) {
            // Quand l'utilisateur clique sur un rendez-vous
            currentAppointmentId = info.event.id;
            editAppointment(info.event);
        },
        eventDrop: function(info) {
            // Quand l'utilisateur déplace un rendez-vous
            updateAppointmentTime(info.event);
        },
        eventResize: function(info) {
            // Quand l'utilisateur redimensionne un rendez-vous
            updateAppointmentDuration(info.event);
        }
    });

    calendar.render();

    // Gestion du formulaire
    document.getElementById('appointmentForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(this);

        if (currentAppointmentId) {
            // Mode édition
            fetch(`/rendezvous/${currentAppointmentId}`, {
                method: 'PUT',
                body: formData,
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    calendar.refetchEvents();
                    resetForm();
                    alert('Rendez-vous modifié avec succès');
                }
            });
        } else {
            // Mode création
            fetch('/rendezvous', {
                method: 'POST',
                body: formData,
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                    'Accept': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    calendar.refetchEvents();
                    this.reset();
                    alert('Rendez-vous créé avec succès');
                }
            });
        }
    });

    // Fonctions utilitaires
    function editAppointment(event) {
        // Remplir le formulaire pour édition
        document.getElementById('appointmentModalTitle').textContent = 'Modifier Rendez-vous';
        document.querySelector('select[name="patient_id"]').value = event.extendedProps.patient_id;
        document.querySelector('select[name="medecin_id"]').value = event.extendedProps.medecin_id;
        document.querySelector('input[name="date_heure"]').value = event.start.toISOString().substring(0, 16);
        document.querySelector('select[name="duree"]').value = event.extendedProps.duree;
        document.querySelector('select[name="type"]').value = event.extendedProps.type;
        document.querySelector('textarea[name="motif"]').value = event.extendedProps.motif || '';
        const modal = new bootstrap.Modal(document.getElementById('appointmentModal'));
        modal.show();
    }

    function updateAppointmentTime(event) {
        fetch(`/rendezvous/${event.id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
            },
            body: JSON.stringify({
                date_heure: event.start.toISOString()
            })
        });
    }

    function updateAppointmentDuration(event) {
        const duration = Math.round((event.end - event.start) / 60000);
        fetch(`/rendezvous/${event.id}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
            },
            body: JSON.stringify({
                duree: duration
            })
        });
    }

    function resetForm() {
        currentAppointmentId = null;
        document.getElementById('appointmentForm').reset();
        document.getElementById('btnUpdate').classList.add('d-none');
        document.getElementById('btnDelete').classList.add('d-none');
        document.getElementById('btnCancel').classList.add('d-none');
    }

    // Charger les statistiques
    function loadStatistics() {
        fetch('/api/rendezvous/statistics')
            .then(response => response.json())
            .then(data => {
                document.getElementById('todayCount').textContent = data.today || 0;
                document.getElementById('weekCount').textContent = data.week || 0;
                document.getElementById('pendingCount').textContent = data.pending || 0;
                document.getElementById('cancelledCount').textContent = data.cancelled || 0;
            });
    }

    // Gestion du formulaire patient
    document.getElementById('patientForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(this);

        fetch('/patients', {
            method: 'POST',
            body: formData,
            headers: {
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content,
                'Accept': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Fermer la modal patient
                const patientModal = bootstrap.Modal.getInstance(document.getElementById('patientModal'));
                patientModal.hide();

                // Ajouter le nouveau patient au select
                const patientSelect = document.getElementById('patientSelect');
                const newOption = new Option(`${data.patient.nom} ${data.patient.prenom}`, data.patient.id);
                patientSelect.appendChild(newOption);
                patientSelect.value = data.patient.id;

                // Réinitialiser le formulaire patient
                this.reset();

                alert('Patient créé avec succès');
            } else {
                alert('Erreur lors de la création du patient');
            }
        })
        .catch(error => {
            console.error('Erreur:', error);
            alert('Erreur lors de la création du patient');
        });
    });

    // Charger les données initiales
    loadStatistics();
    setInterval(loadStatistics, 60000); // Rafraîchir toutes les minutes
});
</script>
@endpush
